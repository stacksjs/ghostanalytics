<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Analytics for blogs and publishers - ghostanalytics</title>
    <meta name="description" content="Cookieless analytics for blogs and publishers. See which posts hold attention, which referrers send readers who stay, and keep pages fast with a script under 2 KB. Powered by ghostanalytics.">
    <meta name="theme-color" content="#0a0c0e">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap">
    <link rel="stylesheet" href="/marketing.css">
  </head>
  <body>
    @include('site-nav')

    <main>
      <nav class="shell subnav" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/use-cases" data-no-router>Use cases</a><span class="sep">/</span>
        <span>Publishers &amp; blogs</span>
      </nav>

      <section class="hero shell">
        <div>
          <p class="enter eyebrow">For blogs &amp; publishers</p>
          <h1 class="d1 enter hero-title">Know what readers actually read.</h1>
          <p class="d2 enter hero-sub">
            See your top articles, where a spike from Hacker News or Reddit came from, and how a post performs over time. All from a script under 2 KB that never slows the page down.
          </p>
          <div class="d3 enter hero-actions">
            <a class="btn primary" href="/#install">Get your script tag</a>
            <a class="btn ghost" href="/dashboard">See a live dashboard</a>
          </div>
        </div>

        <aside class="d2 enter panel" aria-label="Sample top articles">
          <div class="panel-head">
            <span class="live">Top articles, last 30 days</span>
            <span class="panel-tag">Sample data</span>
          </div>
          <svg viewBox="0 0 360 300" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Top articles ranked by readers over the last 30 days, with Core Web Vitals all in the good range" style="display:block;width:100%;height:auto;margin-top:1.1rem">
            <text x="16" y="26" fill="#c9cfd2" font-family="'Geist',sans-serif" font-size="12" font-weight="600">The case against cookie banners</text>
            <text x="344" y="26" text-anchor="end" fill="#eef2f3" font-family="'Geist Mono',monospace" font-size="11">18,410</text>
            <rect x="16" y="34" width="328" height="10" rx="5" fill="rgba(233,238,240,0.07)"></rect>
            <rect x="16" y="34" width="328" height="10" rx="5" fill="#46d3c0" fill-opacity="0.92"></rect>

            <text x="16" y="70" fill="#9aa4a9" font-family="'Geist',sans-serif" font-size="12" font-weight="500">How we cut page weight in half</text>
            <text x="344" y="70" text-anchor="end" fill="#c9cfd2" font-family="'Geist Mono',monospace" font-size="11">11,240</text>
            <rect x="16" y="78" width="328" height="10" rx="5" fill="rgba(233,238,240,0.07)"></rect>
            <rect x="16" y="78" width="200" height="10" rx="5" fill="#46d3c0" fill-opacity="0.66"></rect>

            <text x="16" y="114" fill="#9aa4a9" font-family="'Geist',sans-serif" font-size="12" font-weight="500">A field guide to referrers</text>
            <text x="344" y="114" text-anchor="end" fill="#c9cfd2" font-family="'Geist Mono',monospace" font-size="11">7,880</text>
            <rect x="16" y="122" width="328" height="10" rx="5" fill="rgba(233,238,240,0.07)"></rect>
            <rect x="16" y="122" width="141" height="10" rx="5" fill="#46d3c0" fill-opacity="0.48"></rect>

            <text x="16" y="158" fill="#9aa4a9" font-family="'Geist',sans-serif" font-size="12" font-weight="500">Why we left Google Analytics</text>
            <text x="344" y="158" text-anchor="end" fill="#c9cfd2" font-family="'Geist Mono',monospace" font-size="11">5,120</text>
            <rect x="16" y="166" width="328" height="10" rx="5" fill="rgba(233,238,240,0.07)"></rect>
            <rect x="16" y="166" width="92" height="10" rx="5" fill="#46d3c0" fill-opacity="0.34"></rect>

            <line x1="16" y1="200" x2="344" y2="200" stroke="rgba(233,238,240,0.09)"></line>
            <text x="16" y="222" fill="#6d777c" font-family="'Geist Mono',monospace" font-size="10" letter-spacing="1.2">CORE WEB VITALS</text>
            <text x="344" y="222" text-anchor="end" fill="#46d3c0" font-family="'Geist Mono',monospace" font-size="10" letter-spacing="0.5">ALL GOOD</text>

            <g>
              <rect x="16" y="236" width="104" height="48" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <circle cx="32" cy="256" r="3.5" fill="#46d3c0"></circle>
              <text x="44" y="260" fill="#6d777c" font-family="'Geist Mono',monospace" font-size="9">LCP</text>
              <text x="32" y="277" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="13" font-weight="600">1.2s</text>
            </g>
            <g>
              <rect x="128" y="236" width="104" height="48" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <circle cx="144" cy="256" r="3.5" fill="#46d3c0"></circle>
              <text x="156" y="260" fill="#6d777c" font-family="'Geist Mono',monospace" font-size="9">INP</text>
              <text x="144" y="277" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="13" font-weight="600">40ms</text>
            </g>
            <g>
              <rect x="240" y="236" width="104" height="48" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <circle cx="256" cy="256" r="3.5" fill="#46d3c0"></circle>
              <text x="268" y="260" fill="#6d777c" font-family="'Geist Mono',monospace" font-size="9">CLS</text>
              <text x="256" y="277" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="13" font-weight="600">0.02</text>
            </g>
          </svg>
        </aside>
      </section>

      <section class="reveal section shell" aria-label="A light script keeps pages fast">
        <div class="split">
          <div class="split-text">
            <h3>No ad-tech bloat weighing your pages down.</h3>
            <p>
              Readers leave slow pages, and search rankings follow them. ghostanalytics is a single first-party script under 2 KB, loaded once and deferred, with no gtag.js weight and no third-party fetch storm behind it.
            </p>
            <ul class="mini-list">
              <li><span class="dot" aria-hidden="true"></span>Under 2 KB, deferred, and served from your own domain.</li>
              <li><span class="dot" aria-hidden="true"></span>No cookie banner sitting on top of your reading experience.</li>
              <li><span class="dot" aria-hidden="true"></span>Core Web Vitals beside your traffic, so a slow post stands out.</li>
            </ul>
          </div>
          <aside class="panel" aria-label="Sample referrers">
            <div class="panel-head">
              <span class="live">Where readers arrived from</span>
              <span class="panel-tag">Sample data</span>
            </div>
            <div class="top-pages" style="margin-top:1.1rem;">
              <div class="top-row"><span class="path" style="font-family:var(--sans);">Hacker News</span><span class="bar"><span style="width:100%"></span></span><span class="count">6,120</span></div>
              <div class="top-row"><span class="path" style="font-family:var(--sans);">Reddit</span><span class="bar"><span style="width:66%"></span></span><span class="count">4,040</span></div>
              <div class="top-row"><span class="path" style="font-family:var(--sans);">Organic search</span><span class="bar"><span style="width:52%"></span></span><span class="count">3,180</span></div>
              <div class="top-row"><span class="path" style="font-family:var(--sans);">Newsletter</span><span class="bar"><span style="width:34%"></span></span><span class="count">2,090</span></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="reveal section shell" aria-label="Content performance over time">
        <div class="rev split">
          <div class="split-text">
            <h3>Follow a post from launch-day spike to slow burn.</h3>
            <p>
              A story can peak on day one or find its audience months later. Compare periods to see whether an article keeps pulling traffic, which sources send readers who stick around, and what earns a spot in your newsletter.
            </p>
            <ul class="mini-list">
              <li><span class="dot" aria-hidden="true"></span>Referrers sorted into search, social, and direct automatically.</li>
              <li><span class="dot" aria-hidden="true"></span>Compare this week to last to catch a post finding legs.</li>
              <li><span class="dot" aria-hidden="true"></span>One-click GA import, so your archive's history comes along.</li>
            </ul>
          </div>
          <aside class="panel" aria-label="Sample engagement figures">
            <div class="panel-head">
              <span class="live">This post vs last month</span>
              <span class="panel-tag">Sample data</span>
            </div>
            <div class="metrics" style="margin-top:1.1rem;grid-template-columns:1fr 1fr;gap:1.25rem 1.5rem;">
              <div class="metric"><div class="m-value">3m 12s</div><div class="m-label">Avg. read time</div></div>
              <div class="metric"><div class="m-value">41%</div><div class="m-label">Scrolled to end</div></div>
              <div class="metric"><div class="m-value">+64%</div><div class="m-label">From social</div></div>
              <div class="metric"><div class="m-value">1,940</div><div class="m-label">Newsletter clicks</div></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="reveal section shell" aria-labelledby="pub-track">
        <div class="section-head">
          <h2 id="pub-track" class="section-title">What content teams watch.</h2>
          <p class="section-intro">The signals that tell you what to write next, without profiling a single reader.</p>
        </div>
        <div class="qa-grid">
          <div class="qa"><h4>Top articles</h4><p>Your most-read stories at a glance, so you know which topics keep earning their spot on the front page.</p></div>
          <div class="qa"><h4>Traffic spikes</h4><p>When a link takes off on HN, Reddit, or social, see the source behind the surge in real time.</p></div>
          <div class="qa"><h4>Engagement</h4><p>Read time and scroll depth show whether a headline delivered or just pulled a click and lost the reader.</p></div>
        </div>
      </section>

      <section class="reveal section shell" aria-label="Get started">
        <div class="cta-band">
          <h2>Write for readers, measure like it.</h2>
          <div class="cta-actions">
            <a class="btn primary" href="/#install">Get your script tag</a>
            <a class="btn ghost" href="/use-cases" data-no-router>All use cases</a>
          </div>
        </div>
      </section>
    </main>

    @include('site-footer')
  </body>
</html>
