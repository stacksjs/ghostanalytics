<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Analytics for agencies - ghostanalytics</title>
    <meta name="description" content="Cookieless analytics for agencies and freelancers. Manage every client site from one clean dashboard, share reports in a link, and skip the per-client GA and consent setup. Powered by ghostanalytics.">
    <meta name="theme-color" content="#0a0c0e">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap">
    <link rel="stylesheet" href="/marketing.css">
  </head>
  <body>
    @include('site-nav')

    <main>
      <nav class="shell subnav" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/use-cases" data-no-router>Use cases</a><span class="sep">/</span>
        <span>Agencies</span>
      </nav>

      <section class="hero shell">
        <div>
          <p class="enter eyebrow">For agencies</p>
          <h1 class="d1 enter hero-title">Every client site, one clean dashboard.</h1>
          <p class="d2 enter hero-sub">
            Add a site in seconds, track them all from one login, and share a report your client can read without a walkthrough. No per-client GA project, no consent banner to wrangle.
          </p>
          <div class="d3 enter hero-actions">
            <a class="btn primary" href="/#install">Get your script tag</a>
            <a class="btn ghost" href="/dashboard">See a live dashboard</a>
          </div>
        </div>

        <aside class="d2 enter panel" aria-label="Sample client sites">
          <div class="panel-head">
            <span class="live">Client sites, visitors this month</span>
            <span class="panel-tag">Sample data</span>
          </div>
          <div class="chart-wrap" style="margin-top:1rem">
            <svg class="usecase-viz" viewBox="0 0 360 300" preserveAspectRatio="xMidYMid meet" role="img" aria-label="An agency overview showing four client sites managed from one login: northwind.co 12,480, lumen-studio 7,920, harbor-goods 5,140, and field-notes 3,260 visitors this month" style="display:block;width:100%;height:auto;background:#101317;border-radius:10px">
              <rect x="6" y="6" width="348" height="288" rx="10" fill="#15191e" stroke="rgba(233,238,240,0.09)"></rect>
              <text x="24" y="32" fill="#6d777c" font-family="'Geist Mono',ui-monospace,monospace" font-size="11" letter-spacing="1.2">CLIENT OVERVIEW</text>
              <circle cx="315" cy="28" r="4" fill="#46d3c0"></circle>
              <text x="326" y="32" fill="#46d3c0" font-family="'Geist Mono',ui-monospace,monospace" font-size="11" letter-spacing="0.5">LIVE</text>
              <text x="24" y="62" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="22" font-weight="700" letter-spacing="-0.5">28,800</text>
              <text x="112" y="62" fill="#9aa4a9" font-family="'Geist Mono',ui-monospace,monospace" font-size="10.5">visitors · this month</text>
              <line x1="24" y1="76" x2="336" y2="76" stroke="rgba(233,238,240,0.09)"></line>

              <!-- northwind.co -->
              <rect x="24" y="90" width="150" height="94" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <text x="38" y="114" fill="#9aa4a9" font-family="'Geist Mono',ui-monospace,monospace" font-size="9.5">northwind.co</text>
              <text x="38" y="140" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="16" font-weight="700">12,480</text>
              <polyline points="38,168 58,162 78,164 98,154 118,158 138,146 160,150" fill="none" stroke="#46d3c0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
              <circle cx="160" cy="150" r="3" fill="#46d3c0"></circle>

              <!-- lumen-studio -->
              <rect x="186" y="90" width="150" height="94" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <text x="200" y="114" fill="#9aa4a9" font-family="'Geist Mono',ui-monospace,monospace" font-size="9.5">lumen-studio</text>
              <text x="200" y="140" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="16" font-weight="700">7,920</text>
              <polyline points="200,166 220,160 240,162 260,150 280,156 300,148 322,140" fill="none" stroke="#46d3c0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
              <circle cx="322" cy="140" r="3" fill="#46d3c0"></circle>

              <!-- harbor-goods -->
              <rect x="24" y="192" width="150" height="94" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <text x="38" y="216" fill="#9aa4a9" font-family="'Geist Mono',ui-monospace,monospace" font-size="9.5">harbor-goods</text>
              <text x="38" y="242" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="16" font-weight="700">5,140</text>
              <polyline points="38,270 58,266 78,268 98,258 118,262 138,256 160,252" fill="none" stroke="#46d3c0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
              <circle cx="160" cy="252" r="3" fill="#46d3c0"></circle>

              <!-- field-notes -->
              <rect x="186" y="192" width="150" height="94" rx="8" fill="#101317" stroke="rgba(233,238,240,0.09)"></rect>
              <text x="200" y="216" fill="#9aa4a9" font-family="'Geist Mono',ui-monospace,monospace" font-size="9.5">field-notes</text>
              <text x="200" y="242" fill="#eef2f3" font-family="'Geist',sans-serif" font-size="16" font-weight="700">3,260</text>
              <polyline points="200,268 220,270 240,260 260,264 280,258 300,262 322,256" fill="none" stroke="#46d3c0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
              <circle cx="322" cy="256" r="3" fill="#46d3c0"></circle>
            </svg>
          </div>
        </aside>
      </section>

      <section class="reveal section shell" aria-label="One dashboard, every client">
        <div class="split">
          <div class="split-text">
            <h3>Stop juggling a login for every client.</h3>
            <p>
              One account holds every site you run. Switch between clients from a single menu, keep their numbers separate, and never set up another GA4 property or Consent Mode config again.
            </p>
            <ul class="mini-list">
              <li><span class="dot" aria-hidden="true"></span>Add a new client site with one script tag and a name.</li>
              <li><span class="dot" aria-hidden="true"></span>No cookie banner to configure on each site you touch.</li>
              <li><span class="dot" aria-hidden="true"></span>One-click GA import to bring an inherited account across.</li>
            </ul>
          </div>
          <aside class="panel" aria-label="Sample traffic for one client site">
            <div class="panel-head">
              <span class="live">Top pages, northwind.co</span>
              <span class="panel-tag">Sample data</span>
            </div>
            <div class="top-pages" style="margin-top:1.1rem;">
              <div class="top-row"><span class="path">/</span><span class="bar"><span style="width:100%"></span></span><span class="count">4,210</span></div>
              <div class="top-row"><span class="path">/services</span><span class="bar"><span style="width:58%"></span></span><span class="count">2,440</span></div>
              <div class="top-row"><span class="path">/case-studies</span><span class="bar"><span style="width:39%"></span></span><span class="count">1,630</span></div>
              <div class="top-row"><span class="path">/contact</span><span class="bar"><span style="width:24%"></span></span><span class="count">1,010</span></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="reveal section shell" aria-label="Reports clients understand">
        <div class="rev split">
          <div class="split-text">
            <h3>Send a report, not a login and a lesson.</h3>
            <p>
              Share a clean, read-only dashboard with a single link. Your client sees the numbers that matter, on your schedule, without a GA seat, a training call, or a screenshot deck stitched together the night before.
            </p>
            <ul class="mini-list">
              <li><span class="dot" aria-hidden="true"></span>Shareable dashboards a non-technical client can actually read.</li>
              <li><span class="dot" aria-hidden="true"></span>Compare periods to show the impact of the work you shipped.</li>
              <li><span class="dot" aria-hidden="true"></span>A privacy story you can put in front of any client legal team.</li>
            </ul>
          </div>
          <aside class="panel" aria-label="Sample month over month result">
            <div class="panel-head">
              <span class="live">Visitors vs last month</span>
              <span class="panel-tag">Sample data</span>
            </div>
            <div class="metrics" style="margin-top:1.1rem;grid-template-columns:1fr 1fr;gap:1.25rem 1.5rem;">
              <div class="metric"><div class="m-value">+38%</div><div class="m-label">Visitors</div></div>
              <div class="metric"><div class="m-value">+22%</div><div class="m-label">Conversions</div></div>
              <div class="metric"><div class="m-value">4.9k</div><div class="m-label">From organic</div></div>
              <div class="metric"><div class="m-value">2m 41s</div><div class="m-label">Avg. time on site</div></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="reveal section shell" aria-labelledby="agency-track">
        <div class="section-head">
          <h2 id="agency-track" class="section-title">Built for the way agencies work.</h2>
          <p class="section-intro">The parts that turn analytics from a chore into a deliverable, across every account you manage.</p>
        </div>
        <div class="qa-grid">
          <div class="qa"><h4>Onboard fast</h4><p>A new client is one script tag. No property setup, no consent config, no data-sharing terms to sign.</p></div>
          <div class="qa"><h4>Hand off clean</h4><p>Move a site to the client whenever they want to own it. The data is theirs, not locked in an ad graph.</p></div>
          <div class="qa"><h4>Report on repeat</h4><p>Share the same live link every month, so reporting is a URL, not an all-nighter in a slide tool.</p></div>
        </div>
      </section>

      <section class="reveal section shell" aria-label="Get started">
        <div class="cta-band">
          <h2>Run every client site from one place.</h2>
          <div class="cta-actions">
            <a class="btn primary" href="/#install">Get your script tag</a>
            <a class="btn ghost" href="/use-cases" data-no-router>All use cases</a>
          </div>
        </div>
      </section>
    </main>

    @include('site-footer')
  </body>
</html>
