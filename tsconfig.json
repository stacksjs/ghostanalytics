{
  // Self-contained: a node_modules app has no vendored storage/framework/core
  // to extend, and resolves @stacksjs/* from node_modules (they ship .d.ts) —
  // not from a core/*/src path map. skipLibCheck keeps typecheck on the app's
  // own code rather than the framework's shipped declarations.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      // Router is the ONE @stacksjs/* we pin to the vendored core src (the rest
      // resolve from node_modules). Reason: the framework mixes relative imports
      // (route-loader.ts -> ./stacks-router) with package imports (dev/api.ts ->
      // @stacksjs/router). With a vendored core AND node_modules dist present,
      // those load two physically distinct Router singletons — routes register on
      // one, serve() runs the other, every route 404s (stacksjs/stacks#1975). The
      // upstream fix (#1982, shares the route table across copies via Symbol.for)
      // is unreleased, so we pin resolution to the single vendored copy that
      // carries it. Drop this mapping once node_modules ships a router >= the
      // release containing #1982.
      "@stacksjs/router": ["./storage/framework/core/router/src/index.ts"],
      "@stacksjs/router/*": ["./storage/framework/core/router/src/*"],
      "Actions/*": ["./app/Actions/*"],
      "Commands/*": ["./app/Commands/*"],
      "Jobs/*": ["./app/Jobs/*"],
      "Middleware/*": ["./app/Middleware/*"],
      "Models/*": ["./app/Models/*"],
      "Notifications/*": ["./app/Notifications/*"],
      "~/*": ["./*"],
      "@/*": ["./resources/*"]
    }
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "types/**/*.d.ts",
    "app/Models/**/*.ts",
    "app/Services/**/*.ts",
    "app/Support/**/*.ts"
  ],
  "exclude": [
    "cloud/**",
    "dist/**",
    "node_modules/**",
    "pantry/**",
    "storage/framework/**",
    "resources/assets/**"
  ]
}
