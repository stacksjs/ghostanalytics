{
  // Self-contained: a node_modules app has no vendored storage/framework/core
  // to extend, and resolves @stacksjs/* from node_modules (they ship .d.ts) —
  // not from a core/*/src path map. skipLibCheck keeps typecheck on the app's
  // own code rather than the framework's shipped declarations.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      // @stacksjs/router now resolves from node_modules like every other
      // @stacksjs/* package. It was previously pinned to the vendored core src to
      // avoid the two-Router-singletons bug (stacksjs/stacks#1975) that arises only
      // when a vendored core AND the node_modules dist coexist. With the vendored
      // storage/framework/ tree removed (framework-as-dependencies), there is a
      // single physical router copy — the bundled node_modules dist — so the pin
      // is unnecessary and would point at a nonexistent path.
      "Actions/*": ["./app/Actions/*"],
      "Commands/*": ["./app/Commands/*"],
      "Jobs/*": ["./app/Jobs/*"],
      "Middleware/*": ["./app/Middleware/*"],
      "Models/*": ["./app/Models/*"],
      "Notifications/*": ["./app/Notifications/*"],
      "~/*": ["./*"],
      "@/*": ["./resources/*"]
    }
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "types/**/*.d.ts",
    "app/Models/**/*.ts",
    "app/Services/**/*.ts",
    "app/Support/**/*.ts"
  ],
  "exclude": [
    "cloud/**",
    "dist/**",
    "node_modules/**",
    "pantry/**",
    "storage/framework/**",
    "resources/assets/**"
  ]
}
